# Application
APP_NAME=Project Manager
DEBUG=false

# Database
# 開發：SQLite（不需額外安裝）
DATABASE_URL=sqlite:///./data/project_manager.db
# 生產：PostgreSQL（換掉上面這行）
# DATABASE_URL=postgresql://pm_user:pm_password@db:5432/project_manager

# LINE (Phase 3)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LIFF_ID=

# Claude (Phase 2)
ANTHROPIC_API_KEY=

# BMO worker（bmo 上的 Claude Code headless 執行器）
# 後端與 worker 兩邊要設成相同的值，保護 worker 專用端點
BMO_WORKER_TOKEN=
# 只有這些 LINE userId 能派工（逗號分隔）；留空＝不限制
BMO_ALLOWED_USERS=
# LINE Login channel id（= LIFF_ID 的前綴數字），用來驗證 LIFF id_token
BMO_LINE_CHANNEL_ID=
